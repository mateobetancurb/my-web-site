---
import type { ui } from '../i18n/ui';
interface Props {
  t: typeof ui['en']['hero'];
  lang: 'en' | 'es';
}
const { t, lang } = Astro.props;
---

<section class="pt-40 pb-xl px-gutter max-w-container-max mx-auto grid lg:grid-cols-2 gap-12 items-center">
  <div class="space-y-8">
    <div class="inline-flex items-center gap-2 px-4 py-2 bg-surface-container rounded-full text-primary text-label-md">
      <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
      {t.badge}
    </div>
    <h1 class="text-display leading-tight">
      {t.headline} <span class="text-primary-container">{t.headlineHighlight}</span>
    </h1>
    <p class="text-body-lg text-on-surface-variant max-w-[32rem]">
      {t.body}
    </p>
    <div class="flex flex-wrap gap-4">
      <a class="bg-primary text-on-primary px-8 py-4 rounded-xl text-label-md hover:shadow-lg transition-all active:scale-95" href={`/${lang}/#projects`}>{t.ctaPrimary}</a>
      <a class="border-2 border-primary text-primary px-8 py-4 rounded-xl text-label-md hover:bg-surface-container transition-all active:scale-95" href={`/${lang}/#contact`}>{t.ctaSecondary}</a>
    </div>
  </div>
  <div class="relative group">
    <div class="absolute -inset-4 bg-surface-container-high rounded-3xl -z-10 group-hover:rotate-1 transition-transform"></div>
    <img
      class="w-full rounded-2xl shadow-2xl transition-transform duration-500 group-hover:-translate-y-2"
      src="https://lh3.googleusercontent.com/aida-public/AB6AXuCsceWHlCTfPRYyEZiQvvuwNTFDgvyXDo3I0dkruGucA5S9YV84nxNQa9vFtMTwbjtsxj9Ji39Te2cVKyBlra1mgk2e0yRwqVAmYvm9XMJpGQq4ykrcOwZyhftl7xuTmC5MxtQ9HYloNB_16-i3QQ0sE9vhfF0AeFYmoij1vq2d7cEJt36gsIAnTzgG657NRBG96Kt8dFOCLPXc3e2Ciqe5kYtl0qYikwPm-oY5sOtWkvenO14HjCx5DrUAizOBZtGiK7KkttihPqA"
      alt="Mateo Betancur"
      width="600"
      height="600"
      fetchpriority="high"
      loading="eager"
      decoding="sync"
    />
  </div>
</section>
