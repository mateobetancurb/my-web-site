---
import type { UI, Lang } from '../i18n/utils';
interface Props {
  t: UI[Lang]['about'];
}
const { t } = Astro.props;
---

<section class="py-xl bg-surface-container-low" id="about">
  <div class="max-w-container-max mx-auto px-gutter">
    <div class="mb-12">
      <h2 class="text-headline-lg mb-4">{t.headline}</h2>
      <p class="text-body-lg text-on-surface-variant max-w-2xl">
        {t.body}
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {t.stats.map((stat) => (
        <div class="bg-surface-container-lowest p-8 rounded-2xl border border-outline-variant hover:border-primary transition-colors">
          <span class="material-symbols-outlined text-primary text-4xl mb-4" aria-hidden="true">{stat.icon}</span>
          <h3 class="text-headline-md mb-2">{stat.value}</h3>
          <p class="text-body-md text-on-surface-variant">{stat.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
