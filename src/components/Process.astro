---
import type { ui } from '../i18n/ui';
interface Props {
  t: typeof ui['en']['process'];
}
const { t } = Astro.props;
---

<section class="py-xl max-w-container-max mx-auto px-gutter" id="process">
  <h2 class="text-headline-lg text-center mb-16">{t.headline}</h2>
  <div class="flex flex-col md:flex-row gap-8 justify-between items-start">
    {t.steps.map((step, i) => (
      <>
        <div class="flex-1 text-center space-y-4">
          <div class={`w-16 h-16 rounded-full flex items-center justify-center font-bold text-xl mx-auto shadow-sm ${i === t.steps.length - 1 ? 'bg-primary text-on-primary' : 'bg-surface-container text-primary'}`}>
            {i + 1}
          </div>
          <h3 class="text-headline-md">{step.title}</h3>
          <p class="text-on-surface-variant text-body-md">{step.description}</p>
        </div>
        {i < t.steps.length - 1 && (
          <div class="hidden md:block pt-8 text-outline-variant">
            <span class="material-symbols-outlined" aria-hidden="true">trending_flat</span>
          </div>
        )}
      </>
    ))}
  </div>
</section>
