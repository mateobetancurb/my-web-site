---
import type { ui } from '../i18n/ui';
interface Props {
  t: typeof ui['en']['services'];
}
const { t } = Astro.props;
---

<section class="py-xl bg-surface">
  <div class="max-w-container-max mx-auto px-gutter">
    <div class="text-center mb-16">
      <span class="text-label-md text-primary uppercase tracking-widest">{t.eyebrow}</span>
      <h2 class="text-headline-lg mt-2">{t.headline}</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {t.items.map((item) => (
        <div class="service-card group p-8 bg-surface-container-lowest rounded-2xl shadow-sm hover:shadow-xl transition-all">
          <div class="icon-bg w-12 h-12 rounded-xl bg-surface-container flex items-center justify-center text-primary mb-6 transition-all">
            <span class="material-symbols-outlined" aria-hidden="true">{item.icon}</span>
          </div>
          <h3 class="text-headline-md mb-2">{item.title}</h3>
          <p class="text-body-md text-on-surface-variant">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
