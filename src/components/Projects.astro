---
import type { UI, Lang } from '../i18n/utils';
interface Props {
  t: UI[Lang]['projects'];
}
const { t } = Astro.props;

const socialIcons: Record<string, string> = {
  facebook:
    'M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.84c0-2.52 1.49-3.91 3.77-3.91 1.09 0 2.23.2 2.23.2v2.47h-1.25c-1.24 0-1.62.77-1.62 1.56v1.9h2.76l-.44 2.91h-2.32V22C18.34 21.24 22 17.08 22 12.06Z',
  instagram:
    'M7.8 2h8.4A5.81 5.81 0 0 1 22 7.8v8.4a5.81 5.81 0 0 1-5.8 5.8H7.8A5.81 5.81 0 0 1 2 16.2V7.8A5.81 5.81 0 0 1 7.8 2Zm-.2 2A3.6 3.6 0 0 0 4 7.6v8.8A3.6 3.6 0 0 0 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6A3.6 3.6 0 0 0 16.4 4H7.6Zm9.65 1.5a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z',
  tiktok:
    'M16.6 5.82a5.54 5.54 0 0 0 3.2 1.02v3.21a8.72 8.72 0 0 1-3.17-.61 8.98 8.98 0 0 1-1.23-.62v6.18a6.1 6.1 0 1 1-6.1-6.1c.43 0 .85.04 1.25.13v3.28a2.88 2.88 0 1 0 1.98 2.74V2h3.2c.08.72.36 2.49.87 3.82Z',
  whatsapp:
    'M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.39-1.47-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.21 3.08c.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.63.71.23 1.36.2 1.87.12.57-.09 1.76-.72 2.01-1.41.25-.7.25-1.29.17-1.42-.07-.12-.27-.2-.57-.35ZM12.05 21.79h-.01a9.88 9.88 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26C2.16 6.45 6.6 2.01 12.05 2.01c2.64 0 5.12 1.03 6.99 2.9a9.83 9.83 0 0 1 2.89 6.99c0 5.45-4.43 9.89-9.88 9.89Zm8.41-18.3A11.82 11.82 0 0 0 12.05 0C5.49 0 .16 5.34.16 11.89c0 2.1.55 4.14 1.59 5.95L.06 24l6.31-1.65a11.88 11.88 0 0 0 5.68 1.45h.01c6.55 0 11.89-5.34 11.89-11.89a11.82 11.82 0 0 0-3.49-8.42Z',
};
---

<section class="py-xl max-w-container-max mx-auto px-gutter" id="projects" data-projects-slider data-projects-total={t.items.length}>
  <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
    <div>
      <span class="text-label-md text-primary uppercase tracking-widest">{t.eyebrow}</span>
      <h2 class="text-headline-lg mt-2">{t.headline}</h2>
    </div>
    <div class="flex items-center gap-5">
      <div class="hidden sm:flex items-center gap-3 min-w-32" aria-live="polite">
        <span class="text-label-md text-primary tabular-nums" data-projects-current>01</span>
        <div class="h-px w-16 bg-outline-variant overflow-hidden">
          <div class="h-full w-1/4 bg-primary transition-[width] duration-700 ease-out" data-projects-progress></div>
        </div>
        <span class="text-label-md text-on-surface-variant tabular-nums">{String(t.items.length).padStart(2, '0')}</span>
      </div>
      <div class="flex gap-3">
        <button type="button" aria-label="Previous projects" data-projects-prev class="w-12 h-12 rounded-full border border-outline flex items-center justify-center hover:bg-primary hover:text-on-primary transition-all active:scale-95">
          <span class="material-symbols-outlined" aria-hidden="true">chevron_left</span>
        </button>
        <button type="button" aria-label="Next projects" data-projects-next class="w-12 h-12 rounded-full border border-outline flex items-center justify-center hover:bg-primary hover:text-on-primary transition-all active:scale-95">
          <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
        </button>
      </div>
    </div>
  </div>

  <div class="relative overflow-hidden rounded-xl bg-surface-container-low border border-outline-variant/60" data-projects-stage>
    {t.items.map((project, index) => (
      <article
        class:list={[
          'grid lg:grid-cols-[minmax(0,1.25fr)_minmax(340px,0.75fr)] gap-0 transition-[opacity,transform] duration-700 ease-out',
          index === 0 ? 'relative opacity-100 translate-x-0' : 'absolute inset-0 opacity-0 translate-x-4 pointer-events-none',
        ]}
        data-project-slide
        data-project-index={index}
        aria-hidden={index !== 0}
        inert={index !== 0}
      >
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative block min-h-[320px] lg:min-h-[560px] overflow-hidden bg-surface-container-high"
          aria-label={`${t.cta}: ${project.title}`}
          data-project-media
        >
          <img
            src={project.image}
            alt=""
            loading={index === 0 ? 'eager' : 'lazy'}
            decoding="async"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-1000 ease-out group-hover:scale-[1.025]"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-on-surface/25 via-transparent to-transparent opacity-70"></div>
        </a>

        <div class="flex min-h-[420px] flex-col justify-between gap-12 p-8 md:p-10 lg:p-12 bg-surface-container-lowest" data-project-content>
          <div>
            <div class="flex flex-wrap gap-x-4 gap-y-2 mb-8">
              {project.tags.map((tag) => (
                <span class="text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">{tag}</span>
              ))}
            </div>
            <p class="text-label-md text-primary tabular-nums mb-5">{String(index + 1).padStart(2, '0')}</p>
            <h3 class="text-headline-lg mb-5">{project.title}</h3>
            <p class="text-body-lg text-on-surface-variant max-w-[34rem]">{project.description}</p>
          </div>

          <div class="flex flex-wrap items-center justify-between gap-5">
            <a
              class="inline-flex items-center gap-2 text-label-md text-primary border-b border-primary/20 hover:border-primary transition-all"
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              {t.cta} <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
            </a>
            {project.socials.length > 0 && (
              <div class="flex items-center gap-2">
                {project.socials.map((social) => (
                  <a
                    href={social.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${project.title} ${social.label}`}
                    class="flex h-9 w-9 items-center justify-center rounded-full border border-outline-variant text-primary transition-all hover:bg-primary hover:text-on-primary hover:border-primary active:scale-95"
                  >
                    <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                      <path d={socialIcons[social.icon]} />
                    </svg>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </article>
    ))}

    <div class="absolute bottom-5 left-5 flex gap-2" aria-hidden="true">
      {t.items.map((_, index) => (
        <span
          class:list={[
            'h-1.5 rounded-full transition-all duration-700 ease-out',
            index === 0 ? 'w-8 bg-primary' : 'w-1.5 bg-surface-container-lowest/70',
          ]}
          data-project-dot
        ></span>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-projects-slider]').forEach((slider) => {
    const slides = Array.from(slider.querySelectorAll<HTMLElement>('[data-project-slide]'));
    const dots = Array.from(slider.querySelectorAll<HTMLElement>('[data-project-dot]'));
    const previousButton = slider.querySelector<HTMLButtonElement>('[data-projects-prev]');
    const nextButton = slider.querySelector<HTMLButtonElement>('[data-projects-next]');
    const currentLabel = slider.querySelector<HTMLElement>('[data-projects-current]');
    const progress = slider.querySelector<HTMLElement>('[data-projects-progress]');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const total = slides.length;
    let activeIndex = 0;

    const activate = (nextIndex: number) => {
      if (total === 0) return;

      activeIndex = (nextIndex + total) % total;
      if (currentLabel) {
        currentLabel.textContent = String(activeIndex + 1).padStart(2, '0');
      }
      if (progress) {
        progress.style.width = `${((activeIndex + 1) / total) * 100}%`;
      }

      slides.forEach((slide, index) => {
        const isActive = index === activeIndex;
        slide.classList.toggle('relative', isActive);
        slide.classList.toggle('absolute', !isActive);
        slide.classList.toggle('inset-0', !isActive);
        slide.classList.toggle('opacity-100', isActive);
        slide.classList.toggle('opacity-0', !isActive);
        slide.classList.toggle('translate-x-0', isActive);
        slide.classList.toggle('translate-x-4', !isActive && !prefersReducedMotion);
        slide.classList.toggle('pointer-events-none', !isActive);
        slide.toggleAttribute('inert', !isActive);
        slide.setAttribute('aria-hidden', String(!isActive));
      });

      dots.forEach((dot, index) => {
        const isActive = index === activeIndex;
        dot.classList.toggle('w-8', isActive);
        dot.classList.toggle('w-1.5', !isActive);
        dot.classList.toggle('bg-primary', isActive);
        dot.classList.toggle('bg-surface-container-lowest/70', !isActive);
      });
    };

    previousButton?.addEventListener('click', () => {
      activate(activeIndex - 1);
    });

    nextButton?.addEventListener('click', () => {
      activate(activeIndex + 1);
    });

    activate(0);
  });
</script>
