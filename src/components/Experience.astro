---
import type { UI, Lang } from '../i18n/utils';
interface Props {
  t: UI[Lang]['experience'];
}
const { t } = Astro.props;
---

<section class="py-xl bg-surface-container-low" id="experience">
  <div class="max-w-container-max mx-auto px-gutter">
    <h2 class="text-headline-lg mb-16 text-center">{t.headline}</h2>
    <div class="space-y-8 max-w-4xl mx-auto">
      {t.jobs.map((job, i) => (
        <div class={`relative pl-12 border-l border-outline-variant ${i === t.jobs.length - 1 ? 'pb-0' : 'pb-12'}`}>
          <div class={`absolute left-[-12px] top-0 w-6 h-6 rounded-full ring-4 ring-background ${job.dotClass}`}></div>
          <div class="flex flex-col md:flex-row md:justify-between mb-4">
            <div>
              <h3 class="text-headline-md">{job.title}</h3>
              <p class="text-primary text-label-md">{job.company}</p>
            </div>
            <p class="text-on-surface-variant text-label-md">{job.period}</p>
          </div>
          <p class="text-on-surface-variant">{job.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
