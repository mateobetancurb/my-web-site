---
import type { ui } from '../i18n/ui';
interface Props {
  t: typeof ui['en']['header'];
  lang: 'en' | 'es';
}
const { t, lang } = Astro.props;
const altLang = lang === 'en' ? 'es' : 'en';
---

<header class="fixed top-0 left-0 right-0 z-50 glass-nav border-b border-surface-variant bg-surface/80">
  <div class="max-w-container-max mx-auto px-gutter h-20 flex justify-between items-center">
    <a class="text-headline-md font-bold text-primary tracking-tighter" href={`/${lang}/`}>Mateo Betancur</a>
    <nav class="hidden md:flex gap-8 items-center">
      <a class="text-label-md text-on-surface-variant hover:text-primary transition-colors" href={`/${lang}/#about`}>{t.nav.about}</a>
      <a class="text-label-md text-on-surface-variant hover:text-primary transition-colors" href={`/${lang}/#skills`}>{t.nav.skills}</a>
      <a class="text-label-md text-on-surface-variant hover:text-primary transition-colors" href={`/${lang}/#projects`}>{t.nav.projects}</a>
      <a class="text-label-md text-on-surface-variant hover:text-primary transition-colors" href={`/${lang}/#experience`}>{t.nav.experience}</a>
      <a class="text-label-md text-on-surface-variant hover:text-primary transition-colors" href={`/${lang}/#process`}>{t.nav.process}</a>
      <a class="text-label-md bg-primary-container text-on-primary-container px-6 py-3 rounded-full hover:opacity-90 transition-all" href={`/${lang}/#contact`}>{t.nav.contact}</a>
    </nav>
    <div class="flex items-center gap-1 lang-switcher">
      <a
        href="/en/"
        data-lang="en"
        class={`text-label-md px-3 py-1 rounded-full transition-colors ${lang === 'en' ? 'bg-primary text-on-primary' : 'text-on-surface-variant hover:text-primary'}`}
      >EN</a>
      <a
        href="/es/"
        data-lang="es"
        class={`text-label-md px-3 py-1 rounded-full transition-colors ${lang === 'es' ? 'bg-primary text-on-primary' : 'text-on-surface-variant hover:text-primary'}`}
      >ES</a>
    </div>
    <button class="md:hidden text-primary">
      <span class="material-symbols-outlined">menu</span>
    </button>
  </div>
</header>

<script>
  document.querySelectorAll('.lang-switcher a[data-lang]').forEach((link) => {
    link.addEventListener('click', () => {
      const lang = link.getAttribute('data-lang');
      if (lang) localStorage.setItem('lang', lang);
    });
  });
</script>
